{
  "cli": {
    "version": ">= 16.17.3",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "developmentClient": true
      },
      "env": {
        "APP_ENV": "local",
        "APP_VARIANT": "local",
        "EXPO_PUBLIC_BACKEND_URL": "https://rescuenect-staging-api.onrender.com"
      }
    },
    "staging": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "APP_VARIANT": "staging",
        "APP_ENV": "staging",
        "EXPO_PUBLIC_BACKEND_URL": "https://rescuenect-staging-api.onrender.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "APP_VARIANT": "production",
        "APP_ENV": "production-preview",
        "EXPO_PUBLIC_BACKEND_URL": "https://rescuenect-backend.onrender.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": { "buildType": "app-bundle" },
      "env": {
        "APP_VARIANT": "production",
        "APP_ENV": "production",
        "EXPO_PUBLIC_BACKEND_URL": "https://rescuenect-backend.onrender.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
